# Screenshotter Environment Variables
# Copy this file to .env and fill in your values

# Site Configuration
SITE_URL=https://your-site-url.vercel.app
SITE_PASSWORD=your-site-password

# Discord Webhooks (Optional - defaults to hardcoded values)
# Uncomment and set if you want to use custom webhooks
# DISCORD_WEBHOOK_DAY_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DISCORD_WEBHOOK_SWING_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DISCORD_WEBHOOK_LONG_TERM_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DISCORD_WEBHOOK_FULL_PORTFOLIO=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Debug Webhooks (Optional - defaults to hardcoded values)
# DEBUG_WEBHOOK_DAY_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DEBUG_WEBHOOK_SWING_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DEBUG_WEBHOOK_LONG_TERM_TRADER=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
# DEBUG_WEBHOOK_FULL_PORTFOLIO=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
